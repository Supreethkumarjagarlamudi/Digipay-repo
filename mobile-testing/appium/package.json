{
  "name": "digipay-appium-typescript",
  "version": "1.0.0",
  "description": "Enterprise iOS Appium Automation Framework with WebdriverIO and TypeScript",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf reports/ screenshots/ logs/ dist/",
    "compile": "tsc",
    "test": "npx wdio run config/wdio.conf.ts",
    "test:smoke": "npx wdio run config/wdio.conf.ts --suite smoke",
    "test:functional": "npx wdio run config/wdio.conf.ts --suite functional",
    "test:uiux": "npx wdio run config/wdio.conf.ts --suite uiux",
    "test:validation": "npx wdio run config/wdio.conf.ts --suite validation",
    "test:navigation": "npx wdio run config/wdio.conf.ts --suite navigation",
    "test:regression": "npx wdio run config/wdio.conf.ts --suite regression",
    "test:performance": "npx wdio run config/wdio.conf.ts --suite performance",
    "test:accessibility": "npx wdio run config/wdio.conf.ts --suite accessibility",
    "generate-reports": "ts-node utilities/report_compiler.ts"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "pdfkit": "^0.15.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.12.7",
    "@types/pdfkit": "^0.13.4",
    "@wdio/cli": "^8.36.0",
    "@wdio/local-runner": "^8.36.0",
    "@wdio/mocha-framework": "^8.35.0",
    "@wdio/spec-reporter": "^8.32.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "webdriverio": "^8.36.0"
  }
}
