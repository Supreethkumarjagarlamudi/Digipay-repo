# Appium iOS Environment Configuration for DIGIPAY
# Copy this to .env and fill in your values

# ── Appium Server ─────────────────────────────────────────────────────────────
APPIUM_HOST=http://127.0.0.1
APPIUM_PORT=4723

# ── iOS Device / Simulator ────────────────────────────────────────────────────
# macOS 15 / Xcode 16 ships with iOS 18.x simulators
IOS_VERSION=18.2
IOS_DEVICE_NAME=iPhone 16

# ── App Configuration ─────────────────────────────────────────────────────────
APP_BUNDLE_ID=com.supreeth.Digipay

# Full path to the .app bundle (simulator build)
# Example: ~/Library/Developer/Xcode/DerivedData/Digipay-xxx/Build/Products/Debug-iphonesimulator/Digipay.app
APP_PATH=

# ── Optional: Target a specific booted simulator by UDID ─────────────────────
# Run: xcrun simctl list devices booted
# SIMULATOR_UDID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
