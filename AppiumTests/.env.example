# Appium iOS Environment Configuration for DIGIPAY
# Copy this to .env and fill in your values

# ── Appium Server ─────────────────────────────────────────────────────────────
APPIUM_HOST=http://127.0.0.1
APPIUM_PORT=4723

# ── iOS Device / Simulator ────────────────────────────────────────────────────
IOS_VERSION=17.0
IOS_DEVICE_NAME=iPhone 15

# ── App Configuration ─────────────────────────────────────────────────────────
APP_BUNDLE_ID=com.supreeth.Digipay

# Full path to the .app bundle (simulator build)
# Example: ~/Library/Developer/Xcode/DerivedData/Digipay-xxx/Build/Products/Debug-iphonesimulator/Digipay.app
APP_PATH=

# ── Test Configuration ────────────────────────────────────────────────────────
# TEST_PHONE=9876543210
# TEST_OTP=111111
